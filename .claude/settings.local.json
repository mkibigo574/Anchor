{
  "permissions": {
    "allow": [
      "PowerShell($css = \\(Invoke-WebRequest -Uri \"http://localhost:3010/_next/static/css/app/layout.css\" -UseBasicParsing\\).Content; $checks = @{ \"Brand #1E5AA8\" = $css -match \"30 90 168\"; \"Sky #2D9CFF\" = $css -match \"45 156 255\"; \"Orange #F47A20\" = $css -match \"244 122 32\"; \"Mid grey #8A8A8A\" = $css -match \"138 138 138\"; \"Light grey #D9D9D9\" = $css -match \"217 217 217\" }; $checks.GetEnumerator\\(\\) | ForEach-Object { \"{0}: {1}\" -f $_.Key, $_.Value })"
    ]
  }
}
